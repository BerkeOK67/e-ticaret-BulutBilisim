# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (AWS RDS MySQL) ─────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://admin:yourpassword@your-rds-endpoint.rds.amazonaws.com:3306/ecommerce"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET="replace-this-with-a-strong-secret-key"
JWT_EXPIRES_IN="7d"

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave * for development)
ALLOWED_ORIGINS="*"
